{
  "name": "@hua-labs/dot-aot",
  "version": "0.1.3",
  "description": "Build-time static extraction for @hua-labs/dot — Vite and Babel plugins",
  "license": "MIT",
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    },
    "./vite": {
      "types": "./dist/vite.d.mts",
      "import": "./dist/vite.mjs",
      "default": "./dist/vite.mjs"
    },
    "./babel": {
      "types": "./dist/babel.d.mts",
      "import": "./dist/babel.mjs",
      "default": "./dist/babel.mjs"
    }
  },
  "files": [
    "CHANGELOG.md",
    "DETAILED_GUIDE.md",
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@babel/parser": "^7.29.0",
    "@hua-labs/dot": "workspace:0.2.2"
  },
  "devDependencies": {
    "@babel/core": "^8.0.1",
    "@babel/types": "^8.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.0",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "vite": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/HUA-Labs/hua-packages.git",
    "directory": "packages/hua-dot-aot"
  },
  "bugs": {
    "url": "https://github.com/HUA-Labs/hua-packages/issues"
  },
  "sideEffects": false,
  "engines": {
    "node": ">=20.16.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
