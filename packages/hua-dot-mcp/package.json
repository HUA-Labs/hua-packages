{
  "name": "@hua-labs/dot-mcp",
  "version": "0.1.0",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "description": "MCP server for the dot style engine",
  "type": "module",
  "bin": {
    "dot-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --target es2022",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@hua-labs/dot": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/HUA-Labs/hua-packages.git",
    "directory": "packages/hua-dot-mcp"
  },
  "bugs": {
    "url": "https://github.com/HUA-Labs/hua-packages/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
