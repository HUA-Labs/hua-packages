{
  "name": "@hua-labs/state",
  "version": "1.0.4",
  "description": "HUA State - Unified state management for hua framework with SSR support and integrations",
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    },
    "./integrations/i18n": {
      "types": "./dist/integrations/i18n.d.ts",
      "import": "./dist/integrations/i18n.mjs",
      "default": "./dist/integrations/i18n.mjs"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0",
    "zustand": ">=5.0.0"
  },
  "keywords": [
    "hua-labs",
    "state-management",
    "zustand",
    "react",
    "typescript",
    "ssr",
    "hydration",
    "persistence",
    "i18n",
    "nextjs"
  ],
  "author": "HUA Labs",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/HUA-Labs/hua-packages.git"
  },
  "bugs": {
    "url": "https://github.com/HUA-Labs/hua-packages/issues"
  },
  "homepage": "https://github.com/HUA-Labs/hua-packages#readme",
  "sideEffects": false,
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "zustand": "^5.0.0"
  }
}
