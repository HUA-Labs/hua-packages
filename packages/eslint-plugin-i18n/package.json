{
  "name": "@hua-labs/eslint-plugin-i18n",
  "version": "0.1.2",
  "description": "ESLint plugin for i18n type safety — missing keys, unused keys, raw text, dynamic keys",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "bin": {
    "i18n-lint": "./dist/cli/index.js"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest watch"
  },
  "devDependencies": {
    "@babel/eslint-parser": "^7.29.7",
    "@babel/preset-react": "^7.29.7",
    "@types/eslint": "^9.0.0",
    "@types/estree": "^1.0.9",
    "@types/node": "^26.1.1",
    "@typescript-eslint/parser": "^8.62.0",
    "eslint": "^10.6.0",
    "eslint-plugin-react": "^7.37.5",
    "espree": "^11.2.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "peerDependencies": {
    "eslint": ">=8.0.0"
  },
  "keywords": [
    "eslint",
    "eslintplugin",
    "i18n",
    "internationalization",
    "hua-labs"
  ],
  "author": "HUA Labs",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/HUA-Labs/hua-packages.git",
    "directory": "packages/eslint-plugin-i18n"
  }
}
