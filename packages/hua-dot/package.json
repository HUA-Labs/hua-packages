{
  "name": "@hua-labs/dot",
  "version": "0.2.2",
  "description": "Cross-platform style engine — utility strings to Web CSSProperties / RN StyleSheet / Swift / Compose",
  "bin": {
    "dot-codegen": "./dist/codegen/cli.mjs"
  },
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "react-native": {
        "types": "./dist/native.d.mts",
        "import": "./dist/native.mjs"
      },
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    },
    "./native": {
      "types": "./dist/native.d.mts",
      "import": "./dist/native.mjs",
      "default": "./dist/native.mjs"
    },
    "./class": {
      "types": "./dist/class.d.mts",
      "import": "./dist/class.mjs",
      "default": "./dist/class.mjs"
    },
    "./codegen": {
      "types": "./dist/codegen/index.d.mts",
      "import": "./dist/codegen/index.mjs",
      "default": "./dist/codegen/index.mjs"
    }
  },
  "files": [
    "CHANGELOG.md",
    "DETAILED_GUIDE.md",
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "keywords": [
    "style-engine",
    "css-in-js",
    "utility-first",
    "cross-platform",
    "react-native",
    "swift",
    "compose",
    "codegen",
    "typescript"
  ],
  "author": "HUA Labs",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/HUA-Labs/hua-packages.git"
  },
  "sideEffects": false,
  "engines": {
    "node": ">=20.16.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
