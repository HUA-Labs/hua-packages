{
  "name": "@hua-labs/i18n-loaders",
  "version": "2.2.1",
  "description": "Production-ready loaders, caching, and preloading helpers for @hua-labs/i18n-core.",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "exports": {
    ".": {
      "react-native": "./dist/index.mjs",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "default": "./dist/index.mjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "type-check": "tsc --noEmit"
  },
  "sideEffects": false,
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@hua-labs/i18n-core": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=19.0.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "eslint": "^10.6.0",
    "react": "^19.2.7",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "keywords": [
    "hua-labs",
    "i18n",
    "internationalization",
    "translation",
    "loader",
    "preload",
    "cache",
    "react",
    "typescript"
  ],
  "author": "HUA Labs",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/HUA-Labs/hua-packages.git"
  },
  "bugs": {
    "url": "https://github.com/HUA-Labs/hua-packages/issues"
  },
  "homepage": "https://github.com/HUA-Labs/hua-packages#readme",
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
