{
  "name": "@hua-labs/dot-lsp",
  "version": "0.1.4",
  "description": "LSP server for the dot style engine — autocomplete, hover, diagnostics",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "dot-lsp": "./dist/index.js"
  },
  "files": [
    "CHANGELOG.md",
    "DETAILED_GUIDE.md",
    "dist/index.js"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --shims && node -e \"require('node:fs').rmSync('dist/index.d.ts',{force:true})\"",
    "dev": "tsx src/index.ts --stdio",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@hua-labs/dot": "workspace:0.3.0",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.12"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=20.16.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/HUA-Labs/hua-packages.git",
    "directory": "packages/hua-dot-lsp"
  },
  "bugs": {
    "url": "https://github.com/HUA-Labs/hua-packages/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
