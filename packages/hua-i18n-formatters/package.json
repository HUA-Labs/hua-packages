{
  "name": "@hua-labs/i18n-formatters",
  "version": "2.1.0",
  "description": "HUA Labs - Date, Number, and Currency formatting utilities for i18n",
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    },
    "./date": {
      "types": "./dist/date/index.d.ts",
      "import": "./dist/date/index.mjs",
      "default": "./dist/date/index.mjs"
    },
    "./number": {
      "types": "./dist/number/index.d.ts",
      "import": "./dist/number/index.mjs",
      "default": "./dist/number/index.mjs"
    },
    "./currency": {
      "types": "./dist/currency/index.d.ts",
      "import": "./dist/currency/index.mjs",
      "default": "./dist/currency/index.mjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "sideEffects": false,
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@hua-labs/i18n-core": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=19.0.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@testing-library/react-hooks": "^8.0.1",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "@vitest/coverage-v8": "^4.0.18",
    "jsdom": "^28.1.0",
    "react": "^19.2.4",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "keywords": [
    "i18n",
    "internationalization",
    "date",
    "number",
    "currency",
    "formatting",
    "localization"
  ],
  "author": "HUA Labs",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/HUA-Labs/hua-packages.git"
  },
  "bugs": {
    "url": "https://github.com/HUA-Labs/hua-packages/issues"
  },
  "homepage": "https://github.com/HUA-Labs/hua-packages#readme",
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
