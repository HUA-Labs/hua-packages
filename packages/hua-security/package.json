{
  "name": "@hua-labs/security",
  "version": "1.0.0-alpha.0",
  "description": "HUA Labs Security - Encryption, Rate Limiting, Abuse Detection, and more",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.mjs",
      "require": "./dist/server.js"
    },
    "./pro": {
      "types": "./dist/pro.d.ts",
      "import": "./dist/pro.mjs",
      "require": "./dist/pro.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.mjs",
      "require": "./dist/client.js"
    },
    "./adapters": {
      "types": "./dist/adapters.d.ts",
      "import": "./dist/adapters.mjs",
      "require": "./dist/adapters.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "test": "vitest",
    "type-check": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "@google-cloud/kms": "^4.5.0",
    "next": ">=14.0.0"
  },
  "peerDependenciesMeta": {
    "@google-cloud/kms": {
      "optional": true
    },
    "next": {
      "optional": true
    }
  },
  "keywords": [
    "security",
    "encryption",
    "rate-limit",
    "abuse-detection",
    "kms",
    "captcha",
    "redis"
  ],
  "author": "HUA Labs",
  "license": "MIT",
  "sideEffects": false,
  "engines": {
    "node": ">=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/HUA-Labs/HUA-Labs-public.git",
    "directory": "packages/hua-security"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
