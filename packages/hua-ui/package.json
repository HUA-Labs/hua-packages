{
  "name": "@hua-labs/ui",
  "version": "2.2.0",
  "description": "HUA Labs - Modern React UI Component Library - Beautiful, accessible, and customizable components for React applications",
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "react-native": {
        "types": "./dist/native.d.ts",
        "import": "./dist/native.mjs",
        "default": "./dist/native.mjs"
      },
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    },
    "./native": {
      "types": "./dist/native.d.ts",
      "import": "./dist/native.mjs",
      "default": "./dist/native.mjs"
    },
    "./theme": {
      "types": "./dist/theme.d.ts",
      "import": "./dist/theme.mjs",
      "default": "./dist/theme.mjs"
    },
    "./advanced": {
      "types": "./dist/advanced.d.ts",
      "import": "./dist/advanced.mjs",
      "default": "./dist/advanced.mjs"
    },
    "./advanced/dashboard": {
      "types": "./dist/advanced/dashboard.d.ts",
      "import": "./dist/advanced-dashboard.mjs",
      "default": "./dist/advanced-dashboard.mjs"
    },
    "./advanced/motion": {
      "types": "./dist/advanced/motion.d.ts",
      "import": "./dist/advanced-motion.mjs",
      "default": "./dist/advanced-motion.mjs"
    },
    "./advanced/emotion": {
      "types": "./dist/components/advanced/emotion/index.d.ts",
      "import": "./dist/advanced-emotion.mjs",
      "default": "./dist/advanced-emotion.mjs"
    },
    "./form": {
      "types": "./dist/form.d.ts",
      "import": "./dist/form.mjs",
      "default": "./dist/form.mjs"
    },
    "./navigation": {
      "types": "./dist/navigation.d.ts",
      "import": "./dist/navigation.mjs",
      "default": "./dist/navigation.mjs"
    },
    "./feedback": {
      "types": "./dist/feedback.d.ts",
      "import": "./dist/feedback.mjs",
      "default": "./dist/feedback.mjs"
    },
    "./overlay": {
      "types": "./dist/overlay.d.ts",
      "import": "./dist/overlay.mjs",
      "default": "./dist/overlay.mjs"
    },
    "./data": {
      "types": "./dist/data.d.ts",
      "import": "./dist/data.mjs",
      "default": "./dist/data.mjs"
    },
    "./interactive": {
      "types": "./dist/interactive.d.ts",
      "import": "./dist/interactive.mjs",
      "default": "./dist/interactive.mjs"
    },
    "./interactive/kanban": {
      "types": "./dist/interactive/kanban.d.ts",
      "import": "./dist/interactive-kanban.mjs",
      "default": "./dist/interactive-kanban.mjs"
    },
    "./sdui": {
      "types": "./dist/sdui.d.ts",
      "import": "./dist/sdui.mjs",
      "default": "./dist/sdui.mjs"
    },
    "./landing": {
      "types": "./dist/landing.d.ts",
      "import": "./dist/landing.mjs",
      "default": "./dist/landing.mjs"
    },
    "./styles/base.css": "./src/styles/base.css",
    "./styles/toast.css": "./src/styles/toast.css",
    "./styles/codeblock.css": "./src/styles/codeblock.css",
    "./styles/recommended-theme.css": "./src/styles/recommended-theme.css",
    "./styles/utilities.css": "./src/styles/utilities.css",
    "./styles/landing.css": "./src/styles/landing.css",
    "./styles/prose.css": "./src/styles/prose.css",
    "./icons": {
      "types": "./src/components/icons/index.ts",
      "import": "./src/components/icons/index.ts",
      "default": "./src/components/icons/index.ts"
    },
    "./icons-bold": {
      "types": "./src/components/icons-bold/index.ts",
      "import": "./src/components/icons-bold/index.ts",
      "default": "./src/components/icons-bold/index.ts"
    },
    "./iconsax": {
      "types": "./dist/iconsax.d.ts",
      "import": "./dist/iconsax.mjs",
      "default": "./dist/iconsax.mjs"
    },
    "./iconsax-extended": {
      "types": "./dist/iconsax-extended.d.ts",
      "import": "./dist/iconsax-extended.mjs",
      "default": "./dist/iconsax-extended.mjs"
    }
  },
  "files": [
    "dist",
    "src/styles",
    "src/components/icons",
    "src/components/icons-bold"
  ],
  "scripts": {
    "build": "pnpm exec tsup && pnpm exec tsc --emitDeclarationOnly",
    "build:watch": "pnpm exec tsup --watch",
    "dev": "pnpm exec tsup --watch",
    "clean": "rm -rf dist",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "analyze": "node scripts/analyze-bundle.js",
    "build:analyze": "pnpm build && pnpm analyze",
    "lint": "eslint .",
    "lint:strict": "eslint . --max-warnings 0",
    "type-check": "tsc --noEmit",
    "generate:icon-types": "tsx scripts/generate-icon-types.ts",
    "generate:icon-snippets": "tsx scripts/generate-icon-snippets.ts"
  },
  "dependencies": {
    "@floating-ui/react": "^0.27.18",
    "@hua-labs/dot": "workspace:*",
    "@phosphor-icons/react": "^2.1.10",
    "clsx": "^2.1.1",
    "sugar-high": "^0.9.5",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.3.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.0.3",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^17.4.0",
    "jsdom": "^29.0.0",
    "lucide-react": "^0.575.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "rollup-plugin-visualizer": "^7.0.1",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hua-labs/motion-core": ">=2.2.3",
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0",
    "react-native": ">=0.73.0"
  },
  "peerDependenciesMeta": {
    "@dnd-kit/core": {
      "optional": true
    },
    "@dnd-kit/sortable": {
      "optional": true
    },
    "@dnd-kit/utilities": {
      "optional": true
    },
    "@hua-labs/motion-core": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "react-native": {
      "optional": true
    }
  },
  "keywords": [
    "hua-labs",
    "ui-library",
    "react-components",
    "react",
    "typescript",
    "design-system",
    "accessibility",
    "aria",
    "dark-mode",
    "tailwind",
    "nextjs",
    "ssr"
  ],
  "author": "HUA Labs",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/HUA-Labs/hua-packages.git"
  },
  "bugs": {
    "url": "https://github.com/HUA-Labs/hua-packages/issues"
  },
  "homepage": "https://github.com/HUA-Labs/hua-packages#readme",
  "sideEffects": [
    "./src/styles/*.css",
    "./src/styles/prose.css",
    "./dist/iconsax.mjs",
    "./dist/iconsax-extended.mjs"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
