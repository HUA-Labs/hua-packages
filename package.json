{
  "name": "hua-platform",
  "version": "1.0.0",
  "description": "HUA Labs - 감정 인터페이스 플랫폼",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "type-check": "turbo run type-check",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "clean": "turbo run clean",
    "generate:pr": "tsx scripts/generate-pr.ts",
    "generate:devlog": "tsx scripts/generate-devlog.ts",
    "generate:docs": "tsx scripts/generate-docs.ts",
    "generate:docs:validate": "tsx scripts/generate-docs.ts --validate",
    "workspace:check": "node --experimental-strip-types scripts/check-workspace-registry.ts",
    "workspace:report": "node --experimental-strip-types scripts/generate-workspace-report.ts",
    "workspace:audit:public-mirror": "node --experimental-strip-types scripts/audit-public-mirror.ts",
    "workspace:build:packages": "node scripts/run-workspace-task.mjs build --kind package",
    "workspace:type-check": "node scripts/run-workspace-task.mjs type-check",
    "workspace:lint": "node scripts/run-workspace-task.mjs lint",
    "workspace:test": "node scripts/run-workspace-task.mjs test",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "1.58.2",
    "@tailwindcss/postcss": "4.2.2",
    "@types/node": "^25.5.0",
    "@types/react": "19.2.14",
    "@vitejs/plugin-react": "6.0.1",
    "@vitest/browser-playwright": "^4.1.0",
    "@vitest/coverage-v8": "^4.1.0",
    "esbuild": "^0.27.4",
    "eslint": "^10.1.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^17.4.0",
    "handlebars": "^4.7.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "node-gyp": "^12.2.0",
    "playwright": "^1.58.2",
    "pnpm": "^10.32.1",
    "prettier": "^3.8.1",
    "subset-font": "^2.4.0",
    "tailwindcss": "4.2.2",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "turbo": "2.8.20",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "vitest": "^4.1.0",
    "yaml": "^2.8.3",
    "zustand": "^5.0.12"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "packageManager": "pnpm@10.24.0",
  "engines": {
    "node": "24.x",
    "pnpm": ">=10.17.0"
  },
  "dependencies": {
    "@anthropic-ai/claude-code": "2.1.56",
    "pretendard": "^1.3.9"
  },
  "pnpm": {
    "patchedDependencies": {
      "@phosphor-icons/react@2.1.10": "patches/@phosphor-icons__react@2.1.10.patch"
    }
  }
}
