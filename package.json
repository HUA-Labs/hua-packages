{
  "name": "hua-packages",
  "version": "1.0.0",
  "description": "Public HUA Labs package workspace",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "type-check": "turbo run type-check",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "clean": "turbo run clean",
    "check:pack-artifacts": "node scripts/check-pack-artifacts.js",
    "check:public-exposure": "node scripts/check-public-exposure.js",
    "check:publish-allowlist": "node scripts/check-publish-allowlist.js",
    "safe-release:preflight": "node scripts/safe-release.mjs preflight --format=github",
    "safe-release:check": "node scripts/safe-release.mjs check",
    "safe-release:refresh": "node scripts/safe-release.mjs refresh",
    "safe-release:version": "node scripts/safe-release.mjs version",
    "safe-release:pack": "node scripts/safe-release.mjs pack",
    "safe-release:publish": "node scripts/safe-release.mjs publish",
    "generate:docs": "tsx scripts/generate-docs.ts",
    "generate:docs:validate": "tsx scripts/generate-docs.ts --validate && node --test scripts/tests/*docs-conformance.test.mjs",
    "check:npm-provenance": "node scripts/check-npm-provenance.mjs",
    "changeset": "changeset",
    "version-packages": "pnpm safe-release:version",
    "release": "pnpm build && pnpm safe-release:publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "1.61.1",
    "@tailwindcss/postcss": "4.3.1",
    "@types/node": "^25.9.3",
    "@types/react": "19.2.17",
    "@vitejs/plugin-react": "6.0.3",
    "@vitest/browser-playwright": "^4.1.9",
    "@vitest/coverage-v8": "^4.1.9",
    "esbuild": "^0.28.1",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "handlebars": "^4.7.9",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "node-gyp": "^13.0.0",
    "playwright": "^1.61.1",
    "pnpm": "^11.9.0",
    "prettier": "^3.9.1",
    "subset-font": "^2.5.0",
    "tailwindcss": "4.3.1",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "turbo": "2.10.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vitest": "^4.1.9",
    "yaml": "^2.9.0",
    "zustand": "^5.0.14"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": "24.x",
    "pnpm": ">=11.9.0"
  }
}
