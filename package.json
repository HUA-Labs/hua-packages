{
  "name": "hua-packages",
  "version": "1.0.0",
  "description": "Public HUA Labs package workspace",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "type-check": "turbo run type-check",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "clean": "turbo run clean",
    "check:pack-artifacts": "node scripts/check-pack-artifacts.js",
    "check:public-exposure": "node scripts/check-public-exposure.js",
    "check:publish-allowlist": "node scripts/check-publish-allowlist.js",
    "generate:docs": "tsx scripts/generate-docs.ts",
    "generate:docs:validate": "tsx scripts/generate-docs.ts --validate",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "1.61.0",
    "@tailwindcss/postcss": "4.3.1",
    "@types/node": "^25.9.3",
    "@types/react": "19.2.17",
    "@vitejs/plugin-react": "5.2.0",
    "@vitest/browser-playwright": "^4.1.9",
    "@vitest/coverage-v8": "^4.1.9",
    "esbuild": "^0.28.1",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^17.6.0",
    "handlebars": "^4.7.9",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "node-gyp": "^12.4.0",
    "playwright": "^1.61.0",
    "pnpm": "^10.30.3",
    "prettier": "^3.8.4",
    "subset-font": "^2.5.0",
    "tailwindcss": "4.3.1",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "turbo": "2.9.18",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.61.1",
    "vitest": "^4.1.9",
    "yaml": "^2.9.0",
    "zustand": "^5.0.14"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "packageManager": "pnpm@10.24.0",
  "engines": {
    "node": "24.x",
    "pnpm": ">=10.17.0"
  }
}
