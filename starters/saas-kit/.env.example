# ===========================================
# SaaS Starter Kit — Environment Variables
# Copy this file to .env.local and fill in your values
# ===========================================

# --- Database ---
DATABASE_URL="postgresql://user:password@localhost:5432/saas-kit?schema=user"

# --- NextAuth ---
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-here"  # Generate: openssl rand -base64 32

# --- OAuth Providers (enable what you need) ---
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# KAKAO_CLIENT_ID=""
# KAKAO_CLIENT_SECRET=""
# LINE_CLIENT_ID=""
# LINE_CLIENT_SECRET=""
# DISCORD_CLIENT_ID=""
# DISCORD_CLIENT_SECRET=""

# --- Redis (optional, for rate limiting & caching) ---
# REDIS_URL="redis://localhost:6379"

# --- Payment: LemonSqueezy ---
# LEMONSQUEEZY_API_KEY=""
# LEMONSQUEEZY_STORE_ID=""
# LEMONSQUEEZY_WEBHOOK_SECRET=""

# --- Payment: Stripe ---
# STRIPE_SECRET_KEY=""
# STRIPE_PUBLISHABLE_KEY=""
# STRIPE_WEBHOOK_SECRET=""

# --- Payment: Toss (Korea) ---
# TOSS_SECRET_KEY=""
# TOSS_CLIENT_KEY=""
# NEXT_PUBLIC_TOSS_CLIENT_KEY=""

# --- Payment: Paddle ---
# PADDLE_API_KEY=""
# PADDLE_WEBHOOK_SECRET=""

# --- Encryption (KMS) ---
# KMS_KEY_ARN=""
# AWS_REGION="ap-northeast-2"
# ENCRYPTION_KEY=""  # Fallback: openssl rand -base64 32

# --- Email (AWS SES) ---
# AWS_SES_REGION="ap-northeast-2"
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
# EMAIL_FROM="noreply@your-domain.com"

# --- Monitoring (optional) ---
# DISCORD_WEBHOOK_URL=""
# SENTRY_DSN=""
